{
  "name": "activaq-workspace",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @activaq/sdk && npm run build --workspace @activaq/example-nextjs",
    "build:package": "npm run build --workspace @activaq/sdk",
    "build:example": "npm run build --workspace @activaq/example-nextjs",
    "dev:package": "npm run dev --workspace @activaq/sdk",
    "dev:example": "npm run dev --workspace @activaq/example-nextjs",
    "docker:build:demo": "docker build -f examples/nextjs/Dockerfile -t activaq-demo .",
    "test": "npm run test --workspace @activaq/sdk",
    "typecheck": "npm run typecheck --workspace @activaq/sdk && npm run typecheck --workspace @activaq/example-nextjs",
    "check": "npm run test && npm run typecheck && npm run build",
    "postinstall": "npm run build --workspace @activaq/sdk",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "node ./scripts/publish-sdk.mjs",
    "release:changesets": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7"
  }
}
