# Server-side Upstash Redis credentials.
# Leave these empty for local memory-mode demo runs.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Server-side Activa tuning.
ACTIVAQ_NAMESPACE=activaq-demo
ACTIVAQ_PRESENCE_TTL_MS=30000
ACTIVAQ_HEATMAP_BUCKET_MS=300000
ACTIVAQ_HEATMAP_CELL_SIZE=24
ACTIVAQ_LIVE_STREAM_MAX_LEN=2000

# Client-visible demo configuration.
NEXT_PUBLIC_ACTIVAQ_ENDPOINT=/api/activaq
NEXT_PUBLIC_ACTIVAQ_DEMO_ROOM=demo:lobby
NEXT_PUBLIC_ACTIVAQ_DEMO_LABEL=Activaq / Next.js Demo
