# Server-side Upstash Redis credentials.
# Leave these empty for local memory-mode demo runs.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Server-side Activa tuning.
ACTIVA_NAMESPACE=activa-demo
ACTIVA_PRESENCE_TTL_MS=30000
ACTIVA_HEATMAP_BUCKET_MS=300000
ACTIVA_HEATMAP_CELL_SIZE=24
ACTIVA_LIVE_STREAM_MAX_LEN=2000

# Client-visible demo configuration.
NEXT_PUBLIC_ACTIVA_ENDPOINT=/api/activa
NEXT_PUBLIC_ACTIVA_DEMO_ROOM=demo:lobby
NEXT_PUBLIC_ACTIVA_DEMO_LABEL=Activa / Next.js Demo
