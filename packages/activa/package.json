{
  "name": "@activaq/sdk",
  "version": "0.1.0",
  "description": "Activaq is a Redis-powered real-time presence, active user analytics, and session heatmap SDK for modern web apps.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js",
      "require": "./dist/browser.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./hono": {
      "types": "./dist/hono.d.ts",
      "import": "./dist/hono.js",
      "require": "./dist/hono.cjs"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js",
      "require": "./dist/node.cjs"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js",
      "require": "./dist/testing.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup src/index.ts src/browser.ts src/react.ts src/hono.ts src/node.ts src/testing.ts --format esm,cjs --dts --sourcemap --clean",
    "dev": "tsup src/index.ts src/browser.ts src/react.ts src/hono.ts src/node.ts src/testing.ts --format esm,cjs --dts --sourcemap --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "@hono/node-server": "^1.19.6",
    "@hono/node-ws": "^1.2.0",
    "@hono/zod-validator": "^0.7.4",
    "hono": "^4.10.1",
    "zod": "^4.1.9"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "tsup": "^8.5.0",
    "vitest": "^3.2.3",
    "ws": "^8.18.3"
  },
  "keywords": [
    "analytics",
    "presence",
    "redis",
    "upstash",
    "hono",
    "heatmap",
    "realtime",
    "sdk"
  ]
}
